@article{himmelstein2018scihub,
  author    = {Himmelstein, Daniel S. and Romero, Ariel Rodriguez and
               Levernier, Jacob G. and Munro, Thomas Anthony and
               McLaughlin, Stephen Reid and Greshake~Tzovaras, Bastian and
               Greene, Casey S.},
  title     = {Sci-Hub Provides Access to Nearly All Scholarly Literature},
  journal   = {eLife},
  volume    = {7},
  pages     = {e32822},
  year      = {2018},
  month     = mar,
  doi       = {10.7554/eLife.32822},
  pmid      = {29424689},
  pmcid     = {PMC5832410},
  url       = {https://elifesciences.org/articles/32822},
  abstract  = {The website Sci-Hub enables users to download PDF versions of
               scholarly articles, including many articles that are paywalled
               at their journal's site.  As of March 2017, Sci-Hub's
               database contains 68.9\% of the 81.6 million scholarly
               articles registered with Crossref and 85.1\% of articles
               published in toll access journals.},
  keywords  = {open access, Sci-Hub, bibliometrics, shadow library,
               scholarly communication},
}

